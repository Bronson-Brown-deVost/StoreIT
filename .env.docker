# StoreIT Docker Configuration
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.docker .env
#   nano .env
#   docker compose up -d

# --- Database & Storage ---
# These paths are INSIDE the container. The docker-compose.yml maps them
# to ./data/db and ./data/images on your host via bind mounts.
DATABASE_URL=sqlite:/data/db/storeit.db?mode=rwc
STOREIT_IMAGE_PATH=/data/images

# --- Session ---
# IMPORTANT: Change this to a random 32+ character string.
# Generate one with: openssl rand -base64 32
STOREIT_SESSION_SECRET=change-me-to-something-random-and-long

# --- Local Auth ---
# Admin user is created on first startup if no admins exist.
# Change the password before first run.
# STOREIT_ADMIN_USERNAME=admin
# STOREIT_ADMIN_PASSWORD=changeme
# STOREIT_ADMIN_EMAIL=admin@localhost
# STOREIT_ADMIN_DISPLAY_NAME=Administrator

# --- AI Item Identification (optional) ---
# Set your Anthropic API key to enable AI-powered item identification.
# STOREIT_ANTHROPIC_API_KEY=sk-ant-...
# STOREIT_AI_MODEL=claude-haiku-4-5-20251001

# --- OIDC Authentication (optional) ---
# Set STOREIT_AUTH_ISSUER to use OIDC instead of local auth.
# STOREIT_AUTH_ISSUER=https://auth.example.com/application/o/storeit/
# STOREIT_AUTH_CLIENT_ID=storeit
# STOREIT_AUTH_CLIENT_SECRET=your-client-secret
# STOREIT_AUTH_REDIRECT_URI=https://storeit.example.com/api/v1/auth/callback
# STOREIT_AUTH_GROUP_PREFIX=storeit:

# --- Session Tuning ---
# STOREIT_SESSION_TTL_HOURS=24
