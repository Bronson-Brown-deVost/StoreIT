# StoreIT Configuration
# Copy this file to .env and adjust values for your environment.

# --- Database ---
DATABASE_URL=sqlite:./data/storeit.db?mode=rwc

# --- Server ---
STOREIT_BIND=0.0.0.0:8080
STOREIT_IMAGE_PATH=./data/images

# --- Authentication (OIDC) ---
# Set STOREIT_AUTH_ISSUER to use OIDC. Leave unset for local auth (username/password).
# STOREIT_AUTH_ISSUER=https://auth.example.com/application/o/storeit/
# STOREIT_AUTH_CLIENT_ID=storeit
# STOREIT_AUTH_CLIENT_SECRET=changeme
# STOREIT_AUTH_REDIRECT_URI=https://storeit.example.com/api/v1/auth/callback
# STOREIT_AUTH_GROUP_PREFIX=storeit:

# --- Local Auth (when STOREIT_AUTH_ISSUER is not set) ---
# Admin user is seeded on first startup if no admins exist.
# STOREIT_ADMIN_USERNAME=admin
# STOREIT_ADMIN_PASSWORD=changeme
# STOREIT_ADMIN_EMAIL=admin@localhost
# STOREIT_ADMIN_DISPLAY_NAME=Administrator

# --- Session ---
# IMPORTANT: Change this to a random 32+ character string in production.
# STOREIT_SESSION_SECRET=generate-a-random-secret-here-at-least-32-chars
# STOREIT_SESSION_TTL_HOURS=24

# --- AI Item Identification ---
# Set your Anthropic API key to enable AI-powered item identification.
# Without this, the server falls back to the Claude CLI if available.
# STOREIT_ANTHROPIC_API_KEY=sk-ant-...
# STOREIT_AI_MODEL=claude-haiku-4-5-20251001
# STOREIT_CLAUDE_PATH=claude
